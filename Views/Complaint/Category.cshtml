@model IEnumerable<collegemainatanceportal.Models.Complaint>

<h2>Category Complaints</h2>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Title</th>
            <th>Description</th>
            <th>Category</th>
            <th>Priority</th>
            <th>Status</th>
        </tr>
    </thead>

    <tbody>

        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Title</td>
                <td>@item.Description</td>
                <td>@item.Category</td>
                <td>@item.Priority</td>
                <td>@item.Status</td>
            </tr>
        }

    </tbody>
</table>
