@using Microsoft.AspNetCore.Http
<!DOCTYPE html>
<html>
<head>

    <title>College Maintenance Portal</title>

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="~/css/complaint.css" asp-append-version="true" />

</head>

<body>

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">

        <div class="container-fluid">

            <a class="navbar-brand">College Maintenance Portal</a>
<div class="collapse navbar collapse"> </div>

            <div class="navbar-nav ms-auto">


                @if (Context.Session.GetString("Role") == "Student")
                {
                    <a class="btn btn-outline-light me-2"
                       asp-controller="Complaint"
                       asp-action="Create">
                        Create Complaint
                    </a>
                }
                @if (Context.Session.GetString("Role") == "Admin")
                {
                    <a class="nav-link" asp-controller="Dashboard" asp-action="Index">
                        Dashboard
                    </a>
                }

                <a class="btn btn-outline-light me-2" asp-controller="Complaint" asp-action="Index">
                    View Complaints
                </a>

                <a class="btn btn-danger"
                   asp-controller="Account"
                   asp-action="Logout">
                    Logout
                </a>
                @if (Context.Session.GetString("Role") == "Staff")
                {
                    <a asp-action="StaffPage" asp-controller="Complaint" class="btn btn-primary ms-2">
                        Staff Panel
                    </a>
                }

                
                
                    
                    
                 

            </div>

        </div>

    </nav>


    <div class="container mt-4">

        @RenderBody()

    </div>

</body>

</html>